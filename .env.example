# ============================================================================
# UniID v2 Startup Environment
# Copy to `.env` and fill the values before running.
#
# Runtime business settings and feature toggles are managed in:
#   /console/admin/config
# ============================================================================

# --- Core secrets ------------------------------------------------------------
# >= 32 random bytes (base64 or hex). Generate: openssl rand -base64 48
AUTH_JWT_SECRET=
SESSION_COOKIE_SECRET=

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=info
LOG_PRETTY=true

# --- Runtime -----------------------------------------------------------------
NODE_ENV=development
