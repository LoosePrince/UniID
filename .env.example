DATABASE_URL="file:./dev.db"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret"
AUTH_JWT_SECRET="your-auth-jwt-secret"
OBJECT_STORAGE_ENDPOINT_INTERNAL="your-endpoint-internal"
OBJECT_STORAGE_ENDPOINT_EXTERNAL="your-endpoint-external"
OBJECT_STORAGE_BUCKET="your-bucket-name"
OBJECT_STORAGE_ACCESS_KEY="replace-with-access-key"
OBJECT_STORAGE_SECRET_KEY="replace-with-secret-key"
FILE_MAX_SIZE_BYTES="10485760"
FILE_PRESIGN_EXPIRES_SECONDS="300"
FILE_ALLOWED_MIME_TYPES="image/png,image/jpeg,application/pdf"
FILE_SHARE_TOKEN_EXPIRES_IN_SECONDS="604800"

