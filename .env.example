# ============================================================================
# UniID v2 Environment Configuration
# Copy to `.env` and fill the values before running.
# ============================================================================

# --- Core secrets ------------------------------------------------------------
# >= 32 random bytes (base64 or hex). Generate: openssl rand -base64 48
AUTH_JWT_SECRET=
SESSION_COOKIE_SECRET=

# --- Public URL & origins ----------------------------------------------------
PUBLIC_URL="http://localhost:3000"
# Origins (comma separated) allowed to call /api/v1/auth/authorize and admin APIs.
# Defaults to PUBLIC_URL when empty.
ADMIN_ALLOWED_ORIGINS=

# --- Password hashing (argon2id) --------------------------------------------
ARGON2_TIME_COST=3
ARGON2_MEMORY_KB=65536
ARGON2_PARALLELISM=1

# --- Object storage (S3 compatible) -----------------------------------------
S3_ENDPOINT_INTERNAL=
S3_ENDPOINT_EXTERNAL=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_FORCE_PATH_STYLE=true
FILE_MAX_SIZE_BYTES=104857600
FILE_PRESIGN_TTL_SECONDS=300
FILE_SHARE_TOKEN_TTL_SECONDS=604800

# --- Functions (QuickJS sandbox) --------------------------------------------
FN_DEFAULT_MEMORY_MB=64
FN_DEFAULT_TIMEOUT_MS=5000
# Comma separated host whitelist for uniid.fetch(). Empty = network forbidden.
FN_FETCH_WHITELIST=

# --- Realtime (SSE) ----------------------------------------------------------
REALTIME_KEEPALIVE_SECONDS=25
REALTIME_REPLAY_WINDOW_SECONDS=60

# --- Quota & rate limit ------------------------------------------------------
QUOTA_RPS_DEFAULT=60
QUOTA_DAILY_API_DEFAULT=1000000
QUOTA_MONTHLY_STORAGE_BYTES_DEFAULT=10737418240
QUOTA_FN_INVOCATIONS_DAILY_DEFAULT=100000

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=info
LOG_PRETTY=true

# --- Misc --------------------------------------------------------------------
NODE_ENV=development
