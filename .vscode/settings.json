{
    "eslint.validate": [
        "javascript",
        "javascriptreact",
        "typescript",
        "typescriptreact"
    ],
    "eslint.workingDirectories": [
        {
            "mode": "auto"
        }
    ],
    "typescript.tsserver.experimental.enableProjectDiagnostics": true,
    "typescript.validate.enable": true,
    "javascript.validate.enable": true,
    "files.autoSave": "afterDelay"
}