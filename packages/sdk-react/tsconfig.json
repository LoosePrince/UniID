{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM"],
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "declaration": true,
    "incremental": false,
    "baseUrl": ".",
    "paths": {
      "@uniid/sdk": ["../sdk-core/src/index.ts"]
    }
  },
  "include": ["src/**/*"]
}
