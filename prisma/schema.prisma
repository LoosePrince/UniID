generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  email        String?  @unique
  role         String   @default("user")
  createdAt    Int
  updatedAt    Int
  settings     String? // JSON string
  deleted      Int      @default(0)

  sessions     Session[]
  accounts     Account[]
  apps         App[]        @relation("UserApps")
  authorizations Authorization[]
  recordsOwned  Record[]    @relation("RecordOwner")
  recordsCreated Record[]   @relation("RecordCreatedBy")
  recordsUpdated Record[]   @relation("RecordUpdatedBy")
}

model Session {
  id           String  @id @default(cuid())
  userId       String
  token        String  @unique
  refreshToken String? @unique
  expiresAt    Int
  createdAt    Int
  lastActivity Int?
  userAgent    String?

  user User @relation(fields: [userId], references: [id])
}

model App {
  id          String   @id @default(cuid())
  name        String
  domain      String   @unique
  description String?
  createdAt   Int
  ownerId     String
  status      String   @default("active")
  apiKey      String?  @unique
  settings    String? // JSON string
  adminIds    String?  // JSON array of user IDs who are app admins

  owner          User            @relation("UserApps", fields: [ownerId], references: [id])
  authorizations Authorization[]
  records        Record[]
}

model Authorization {
  id          String  @id @default(cuid())
  userId      String
  appId       String
  authType    String
  grantedAt   Int
  expiresAt   Int?
  revoked     Int     @default(0)
  permissions String? // JSON string

  user User @relation(fields: [userId], references: [id])
  app  App  @relation(fields: [appId], references: [id])

  @@unique([userId, appId])
}

model Record {
  id          String  @id @default(cuid())
  appId       String
  ownerId     String?
  dataType    String
  data        String // JSON string
  permissions String // JSON string
  createdAt   Int
  updatedAt   Int
  createdById String?
  updatedById String?
  deleted     Int     @default(0)

  app        App   @relation(fields: [appId], references: [id])
  owner      User? @relation("RecordOwner", fields: [ownerId], references: [id])
  createdBy  User? @relation("RecordCreatedBy", fields: [createdById], references: [id])
  updatedBy  User? @relation("RecordUpdatedBy", fields: [updatedById], references: [id])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String @unique
  expires    DateTime

  @@unique([identifier, token])
}

