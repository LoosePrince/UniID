// UniID v2 schema — clean rewrite
// 设计参考：plan §5

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../data/uniid.db"
}

// ============================================================================
// Users & Sessions
// ============================================================================

model User {
  id              String   @id @default(cuid())
  username        String   @unique
  email           String?  @unique
  emailVerifiedAt Int?
  passwordHash    String
  displayName     String?
  avatar          String?
  role            String   @default("user") // user | admin
  locale          String   @default("zh-CN")
  twoFactorSecret String?
  deletedAt       Int?
  createdAt       Int
  updatedAt       Int

  userSessions    UserSession[]
  appSessions     AppSession[]
  refreshTokens   RefreshToken[]
  appsOwned       App[]              @relation("AppOwner")
  appAdmins       AppAdmin[]
  appApiKeys      AppApiKey[]        @relation("AppApiKeyCreatedBy")
  appDatabases    AppDatabase[]      @relation("AppDatabaseCreatedBy")
  appDatabaseKeys AppDatabaseKey[]   @relation("AppDatabaseKeyCreatedBy")
  authorizations  Authorization[]
  policyDocuments PolicyDocument[]   @relation("PolicyCreatedBy")
  mutationRules    MutationRuleDocument[] @relation("MutationRuleCreatedBy")
  workflows        WorkflowDocument[] @relation("WorkflowCreatedBy")
  dataSchemas     DataSchema[]       @relation("SchemaCreatedBy")
  schemaVersions  SchemaVersion[]    @relation("SchemaVersionCreatedBy")
  recordsOwned    Record[]           @relation("RecordOwner")
  recordsCreated  Record[]           @relation("RecordCreatedBy")
  recordsUpdated  Record[]           @relation("RecordUpdatedBy")
  filesOwned      FileObject[]       @relation("FileOwner")
  fileShares      FileShareToken[]   @relation("FileShareCreatedBy")
  functions       FunctionDefinition[] @relation("FnCreatedBy")
  fnDeployments   FunctionDeployment[] @relation("FnDeploymentBy")
  functionEventTriggers FunctionEventTrigger[] @relation("FnEventTriggerCreatedBy")
  cronJobs        CronJob[]          @relation("CronCreatedBy")
  webhooks        Webhook[]          @relation("HookCreatedBy")
  auditLogs       AuditLog[]

  @@index([role, deletedAt])
}

/// 控制台/账号中心使用的浏览器会话（cookie 持有）。
model UserSession {
  id           String  @id @default(cuid())
  userId       String
  csrfToken    String
  ip           String?
  userAgent    String?
  expiresAt    Int
  lastSeenAt   Int
  createdAt    Int
  revokedAt    Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([expiresAt])
}

/// SDK 持有的 (user × app) 会话，承载 access/refresh 颁发与撤销。
model AppSession {
  id           String  @id @default(cuid())
  userId       String
  appId        String
  authType     String  // full | restricted
  scope        String? // JSON
  ip           String?
  userAgent    String?
  lastSeenAt   Int
  createdAt    Int
  revokedAt    Int?

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  app           App            @relation(fields: [appId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  @@unique([userId, appId])
  @@index([appId, revokedAt])
}

/// 不透明 refresh token：每次刷新生成新条目，并把旧条目标记 usedAt；
/// 若再次见到已用 token，整个会话族 revoke。
model RefreshToken {
  id            String  @id @default(cuid())
  tokenHash     String  @unique // sha-256 of the opaque value
  userId        String
  sessionId     String  // AppSession id
  parentId      String? // 链上前一个 token 的 id
  rotationCount Int     @default(0)
  expiresAt     Int
  createdAt     Int
  usedAt        Int?
  revokedAt     Int?

  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  session AppSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, revokedAt])
  @@index([expiresAt])
}

// ============================================================================
// Apps & Domains
// ============================================================================

model App {
  id             String  @id @default(cuid())
  name           String
  description    String?
  primaryDomain  String  @unique
  status         String  @default("active") // active | suspended | archived
  settings       String? // JSON: { theme?, logoUrl?, brand? }
  createdAt      Int
  updatedAt      Int
  ownerId        String

  owner          User                  @relation("AppOwner", fields: [ownerId], references: [id])
  domains        AppDomain[]
  admins         AppAdmin[]
  apiKeys        AppApiKey[]
  appSessions    AppSession[]
  authorizations Authorization[]
  policies       PolicyDocument[]
  mutationRules  MutationRuleDocument[]
  workflows      WorkflowDocument[]
  schemas        DataSchema[]
  records        Record[]
  databases      AppDatabase[]
  dataStorageBindings DataStorageBinding[]
  files          FileObject[]
  functions      FunctionDefinition[]
  functionEventTriggers FunctionEventTrigger[]
  cronJobs       CronJob[]
  webhooks       Webhook[]
  quota          Quota?
  quotaUsage     QuotaUsage[]
  auditLogs      AuditLog[]
  eventOutbox    EventOutbox[]

  @@index([ownerId, status])
}

/// 额外域名（除 primaryDomain 外，可附加 verified TXT 校验）。
model AppDomain {
  id           String  @id @default(cuid())
  appId        String
  host         String  @unique
  verified     Int     @default(0)
  verifyToken  String? // TXT 验证字符串
  createdAt    Int

  app App @relation(fields: [appId], references: [id], onDelete: Cascade)
}

model AppAdmin {
  id        String @id @default(cuid())
  appId     String
  userId    String
  createdAt Int

  app  App  @relation(fields: [appId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([appId, userId])
}

/// 可选的服务端到服务端 API Key（不影响纯前端理念）。
model AppApiKey {
  id          String  @id @default(cuid())
  appId       String
  label       String
  keyHash     String  @unique
  prefix      String  // 显示用前 8 位
  scopes      String  // JSON 数组
  createdById String
  createdAt   Int
  lastUsedAt  Int?
  revokedAt   Int?

  app       App  @relation(fields: [appId], references: [id], onDelete: Cascade)
  createdBy User @relation("AppApiKeyCreatedBy", fields: [createdById], references: [id])
}

/// App 级独立 SQLite 数据库。平台主库只保存元数据，业务数据落在 path 指向的 SQLite 文件。
model AppDatabase {
  id          String  @id @default(cuid())
  appId       String
  name        String
  filename    String  @unique
  path        String
  status      String  @default("active") // active | disabled | deleted
  note        String?
  createdById String?
  createdAt   Int
  updatedAt   Int
  lastAccessAt Int?
  deletedAt   Int?

  app       App  @relation(fields: [appId], references: [id], onDelete: Cascade)
  createdBy User? @relation("AppDatabaseCreatedBy", fields: [createdById], references: [id])
  keys      AppDatabaseKey[]
  bindings  DataStorageBinding[]

  @@unique([appId, name])
  @@index([appId, status])
}

/// 独立数据库访问 key。明文只在创建/轮换时返回，数据库仅保存 SHA-256 摘要。
model AppDatabaseKey {
  id          String  @id @default(cuid())
  databaseId  String
  label       String
  keyHash     String  @unique
  prefix      String
  createdById String?
  createdAt   Int
  lastUsedAt  Int?
  revokedAt   Int?

  database  AppDatabase @relation(fields: [databaseId], references: [id], onDelete: Cascade)
  createdBy User?       @relation("AppDatabaseKeyCreatedBy", fields: [createdById], references: [id])

  @@index([databaseId, revokedAt])
}

/// dataType 到存储位置的绑定。默认没有绑定时视为 main；迁移后写入 external_sql。
model DataStorageBinding {
  id          String  @id @default(cuid())
  appId       String
  dataType    String
  storageKind String  @default("main") // main | external_sql
  databaseId  String?
  tableName   String?
  migratedAt  Int?
  createdAt   Int
  updatedAt   Int

  app      App          @relation(fields: [appId], references: [id], onDelete: Cascade)
  database AppDatabase? @relation(fields: [databaseId], references: [id], onDelete: SetNull)

  @@unique([appId, dataType])
  @@index([appId, storageKind])
  @@index([databaseId])
}

// ============================================================================
// Authorization (user × app)
// ============================================================================

model Authorization {
  id          String  @id @default(cuid())
  userId      String
  appId       String
  authType    String  // full | restricted
  scope       String? // JSON
  grantedAt   Int
  expiresAt   Int?
  revokedAt   Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  app  App  @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@unique([userId, appId])
  @@index([appId, revokedAt])
}

// ============================================================================
// Policy documents (composable: app / dataType / record overrides)
// ============================================================================

model PolicyDocument {
  id          String  @id @default(cuid())
  appId       String
  scope       String  // app | dataType | record
  target      String? // dataType 名或 recordId，scope=app 时为 null
  document    String  // JSON
  description String?
  createdAt   Int
  updatedAt   Int
  createdById String?

  app       App   @relation(fields: [appId], references: [id], onDelete: Cascade)
  createdBy User? @relation("PolicyCreatedBy", fields: [createdById], references: [id])

  @@unique([appId, scope, target])
  @@index([appId, scope])
}

// ============================================================================
// Mutation rule documents (same-record derived changes)
// ============================================================================

model MutationRuleDocument {
  id          String  @id @default(cuid())
  appId       String
  scope       String  // app | dataType | record
  target      String? // dataType 名或 recordId，scope=app 时为 null
  ruleId      String
  document    String  // JSON
  description String?
  isActive    Int     @default(1)
  createdAt   Int
  updatedAt   Int
  createdById String?

  app       App   @relation(fields: [appId], references: [id], onDelete: Cascade)
  createdBy User? @relation("MutationRuleCreatedBy", fields: [createdById], references: [id])

  @@unique([appId, scope, target, ruleId])
  @@index([appId, scope, isActive])
}

// ============================================================================
// Workflow documents (state machine business process)
// ============================================================================

model WorkflowDocument {
  id          String  @id @default(cuid())
  appId       String
  scope       String  // app | dataType | record
  target      String? // dataType 名或 recordId，scope=app 时为 null
  workflowId  String
  document    String  // JSON
  description String?
  isActive    Int     @default(1)
  createdAt   Int
  updatedAt   Int
  createdById String?

  app       App   @relation(fields: [appId], references: [id], onDelete: Cascade)
  createdBy User? @relation("WorkflowCreatedBy", fields: [createdById], references: [id])

  @@unique([appId, scope, target, workflowId])
  @@index([appId, scope, isActive])
}

// ============================================================================
// Schemas (versioned)
// ============================================================================

model DataSchema {
  id          String  @id @default(cuid())
  appId       String
  dataType    String
  description String?
  createdAt   Int
  updatedAt   Int
  createdById String?

  app       App   @relation(fields: [appId], references: [id], onDelete: Cascade)
  createdBy User? @relation("SchemaCreatedBy", fields: [createdById], references: [id])
  versions  SchemaVersion[]

  @@unique([appId, dataType])
}

model SchemaVersion {
  id              String  @id @default(cuid())
  schemaId        String
  version         Int
  jsonSchema      String  // JSON Schema (AJV)
  autoFill        String? // JSON: { "data.createdAt": "$serverTime", ... }
  validationRules String? // 自定义 JS（QuickJS 沙箱执行）
  isActive        Int     @default(0)
  createdAt       Int
  createdById     String?

  schema    DataSchema @relation(fields: [schemaId], references: [id], onDelete: Cascade)
  createdBy User?      @relation("SchemaVersionCreatedBy", fields: [createdById], references: [id])

  @@unique([schemaId, version])
  @@index([schemaId, isActive])
}

// ============================================================================
// Records
// ============================================================================

model Record {
  id              String  @id @default(cuid())
  appId           String
  dataType        String
  ownerId         String?
  data            String  // JSON
  schemaVersionId String?
  createdAt       Int
  updatedAt       Int
  createdById     String?
  updatedById     String?
  deletedAt       Int?

  app       App   @relation(fields: [appId], references: [id], onDelete: Cascade)
  owner     User? @relation("RecordOwner", fields: [ownerId], references: [id])
  createdBy User? @relation("RecordCreatedBy", fields: [createdById], references: [id])
  updatedBy User? @relation("RecordUpdatedBy", fields: [updatedById], references: [id])

  @@index([appId, dataType, deletedAt])
  @@index([appId, dataType, ownerId])
  @@index([appId, dataType, updatedAt])
}

// ============================================================================
// Files
// ============================================================================

model FileObject {
  id            String  @id @default(cuid())
  appId         String?
  ownerId       String
  bucket        String
  objectKey     String  @unique
  originalName  String
  mimeType      String
  size          Int
  checksum      String?
  checksumAlgo  String? // md5 | sha256
  width         Int?
  height        Int?
  durationMs    Int?
  uploadId      String? // multipart in progress
  visibility    String  @default("private") // private | public
  storageClass  String  @default("standard")
  createdAt     Int
  updatedAt     Int
  deletedAt     Int?

  app         App?             @relation(fields: [appId], references: [id])
  owner       User             @relation("FileOwner", fields: [ownerId], references: [id])
  chunks      FileChunk[]
  shareTokens FileShareToken[]

  @@index([appId, deletedAt])
  @@index([ownerId, deletedAt])
  @@index([createdAt])
}

model FileChunk {
  id         String  @id @default(cuid())
  fileId     String
  uploadId   String
  partNumber Int
  etag       String
  size       Int
  createdAt  Int

  file FileObject @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([uploadId, partNumber])
}

model FileShareToken {
  id          String @id @default(cuid())
  fileId      String
  token       String @unique
  expiresAt   Int
  createdById String
  revokedAt   Int?
  createdAt   Int

  file      FileObject @relation(fields: [fileId], references: [id], onDelete: Cascade)
  createdBy User       @relation("FileShareCreatedBy", fields: [createdById], references: [id])

  @@index([fileId, revokedAt])
  @@index([token, revokedAt, expiresAt])
}

// ============================================================================
// Functions (QuickJS sandbox)
// ============================================================================

model FunctionDefinition {
  id          String  @id @default(cuid())
  appId       String
  name        String
  runtime     String  @default("quickjs")
  env         String? // JSON map
  memoryMb    Int     @default(64)
  timeoutMs   Int     @default(5000)
  isActive    Int     @default(1)
  description String?
  createdAt   Int
  updatedAt   Int
  createdById String?

  app          App                  @relation(fields: [appId], references: [id], onDelete: Cascade)
  createdBy    User?                @relation("FnCreatedBy", fields: [createdById], references: [id])
  deployments  FunctionDeployment[]
  activeDeploymentId String?
  invocations  FunctionInvocation[]
  cronJobs     CronJob[]
  eventTriggers FunctionEventTrigger[]

  @@unique([appId, name])
}

model FunctionDeployment {
  id           String  @id @default(cuid())
  fnId         String
  version      Int
  sourceHash   String
  sourceCode   String
  createdAt    Int
  deployedById String?

  fn         FunctionDefinition @relation(fields: [fnId], references: [id], onDelete: Cascade)
  deployedBy User?              @relation("FnDeploymentBy", fields: [deployedById], references: [id])
  invocations FunctionInvocation[]

  @@unique([fnId, version])
}

model FunctionInvocation {
  id            String  @id @default(cuid())
  fnId          String
  deploymentId  String?
  trigger       String  // http | cron | event | sdk
  status        String  // ok | error | timeout | oom
  durationMs    Int
  memoryPeakKb  Int?
  inputPreview  String? // 截断后的请求载荷
  output        String? // 截断
  logs          String? // captured console.log
  error         String?
  createdAt     Int

  fn         FunctionDefinition  @relation(fields: [fnId], references: [id], onDelete: Cascade)
  deployment FunctionDeployment? @relation(fields: [deploymentId], references: [id])

  @@index([fnId, createdAt])
}

model FunctionEventTrigger {
  id          String  @id @default(cuid())
  appId       String
  fnId        String
  name        String
  events      String  // JSON 数组 ["record.created", "record.*", ...]
  filter      String? // JSON: { dataType?, where? }
  isActive    Int     @default(1)
  createdAt   Int
  updatedAt   Int
  createdById String?

  app       App                @relation(fields: [appId], references: [id], onDelete: Cascade)
  fn        FunctionDefinition @relation(fields: [fnId], references: [id], onDelete: Cascade)
  createdBy User?              @relation("FnEventTriggerCreatedBy", fields: [createdById], references: [id])

  @@unique([appId, name])
  @@index([appId, isActive])
  @@index([fnId, isActive])
}

// ============================================================================
// Cron
// ============================================================================

model CronJob {
  id          String  @id @default(cuid())
  appId       String
  name        String
  cronExpr    String
  fnId        String
  payload     String? // JSON
  isActive    Int     @default(1)
  lastRunAt   Int?
  lastStatus  String?
  nextRunAt   Int?
  createdAt   Int
  updatedAt   Int
  createdById String?

  app       App                @relation(fields: [appId], references: [id], onDelete: Cascade)
  fn        FunctionDefinition @relation(fields: [fnId], references: [id], onDelete: Cascade)
  createdBy User?              @relation("CronCreatedBy", fields: [createdById], references: [id])

  @@unique([appId, name])
  @@index([isActive, nextRunAt])
}

// ============================================================================
// Webhooks
// ============================================================================

model Webhook {
  id          String  @id @default(cuid())
  appId       String
  name        String
  url         String
  secret      String
  events      String  // JSON 数组 ["record.created", ...]
  filter      String? // JSON 过滤器（按 dataType / appId 子集等）
  isActive    Int     @default(1)
  createdAt   Int
  updatedAt   Int
  createdById String?

  app        App                @relation(fields: [appId], references: [id], onDelete: Cascade)
  createdBy  User?              @relation("HookCreatedBy", fields: [createdById], references: [id])
  deliveries WebhookDelivery[]

  @@unique([appId, name])
}

model WebhookDelivery {
  id           String  @id @default(cuid())
  webhookId    String
  eventId      String
  eventType    String
  payload      String  // JSON
  attempt      Int     @default(0)
  status       String  @default("pending") // pending | success | failed | dlq
  statusCode   Int?
  durationMs   Int?
  errorMessage String?
  nextRetryAt  Int?
  createdAt    Int
  updatedAt    Int

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([status, nextRetryAt])
  @@index([webhookId, createdAt])
}

model EventOutbox {
  id             String  @id @default(cuid())
  appId          String?
  eventType      String
  resourceType   String?
  resourceId     String?
  payload        String  // JSON
  status         String  @default("pending") // pending | dispatched | failed | dlq
  attempts       Int     @default(0)
  nextAttemptAt  Int?
  dispatchedAt   Int?
  errorMessage   String?
  causedByEventId String?
  createdAt      Int
  updatedAt      Int

  app App? @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@index([appId, createdAt])
  @@index([eventType, createdAt])
  @@index([status, nextAttemptAt])
  @@index([resourceType, resourceId])
}

// ============================================================================
// Audit log
// ============================================================================

model AuditLog {
  id           String  @id @default(cuid())
  appId        String?
  userId       String?
  action       String
  resourceType String
  resourceId   String?
  before       String? // JSON
  after        String? // JSON
  ip           String?
  userAgent    String?
  requestId    String?
  createdAt    Int

  app  App?  @relation(fields: [appId], references: [id])
  user User? @relation(fields: [userId], references: [id])

  @@index([appId, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
}

// ============================================================================
// Quota & rate limit
// ============================================================================

model Quota {
  id                       String  @id @default(cuid())
  appId                    String  @unique
  rpsLimit                 Int
  dailyApiCalls            Int
  monthlyStorageBytes      BigInt
  monthlyEgressBytes       BigInt
  fnInvocationsDaily       Int
  updatedAt                Int

  app App @relation(fields: [appId], references: [id], onDelete: Cascade)
}

model QuotaUsage {
  id              String @id @default(cuid())
  appId           String
  period          String // "YYYY-MM-DD"
  apiCalls        Int    @default(0)
  fnInvocations   Int    @default(0)
  storageBytes    BigInt @default(0)
  egressBytes     BigInt @default(0)

  app App @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@unique([appId, period])
}

model RateLimitBucket {
  key         String @id // 例如 "app:{id}:ip:{addr}"
  tokens      Int
  refilledAt  Int
}

// ============================================================================
// Global config (k/v)
// ============================================================================

model GlobalConfig {
  key       String @id
  value     String
  updatedAt Int
}
